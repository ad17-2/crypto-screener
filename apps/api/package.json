{
  "name": "@crypto-screener/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9"
  },
  "bin": {
    "crypto-screener": "dist/cli/screener.js",
    "crypto-screener-backfill": "dist/cli/backfill.js",
    "crypto-screener-outcomes": "dist/cli/outcomes.js"
  },
  "scripts": {
    "dev": "cd ../.. && tsx watch apps/api/src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@crypto-screener/contracts": "^0.1.0",
    "better-sqlite3": "^12.0.0",
    "express": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "vitest": "^4.0.0"
  }
}

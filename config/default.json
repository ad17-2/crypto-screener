{
  "version": 2,
  "storage_path": "data/crypto_screener.sqlite3",
  "universe": {
    "quote_asset": "USDT",
    "contract_type": "PERPETUAL",
    "top_symbols_by_volume": 80,
    "min_quote_volume_usd": 20000000,
    "exclude_base_assets": [
      "USDT",
      "USDC",
      "FDUSD",
      "TUSD",
      "BUSD",
      "DAI",
      "USDE",
      "USDP",
      "PYUSD",
      "USD1",
      "USD"
    ]
  },
  "providers": {
    "coinglass": {
      "enabled": true,
      "base_url": "https://open-api-v4.coinglass.com",
      "api_key_env": "COINGLASS_API_KEY",
      "candidate_symbols": 80,
      "min_exchange_count": 2,
      "request_delay_seconds": 2.1,
      "request_timeout_seconds": 12,
      "exchanges": [
        "Binance",
        "OKX",
        "Bybit",
        "Bitget",
        "Gate",
        "Hyperliquid"
      ],
      "technical_indicators": {
        "enabled": true,
        "interval": "4h",
        "limit": 220,
        "max_symbols": 40,
        "request_delay_seconds": 2.1
      },
      "derivatives_history": {
        "enabled": true,
        "interval": "4h",
        "limit": 220,
        "max_symbols": 25,
        "request_delay_seconds": 2.1
      },
      "long_short_ratio": {
        "enabled": true,
        "interval": "4h",
        "limit": 30,
        "max_symbols": 0,
        "ratio_exchange": "Binance",
        "include_top_trader": true,
        "request_delay_seconds": 2.1
      }
    },
    "coingecko": {
      "enabled": true,
      "base_url": "https://api.coingecko.com/api/v3",
      "api_key_env": "COINGECKO_API_KEY",
      "categories_limit": 12,
      "request_timeout_seconds": 12,
      "retry_429": true,
      "retry_429_initial_delay_seconds": 30,
      "retry_429_max_delay_seconds": 300,
      "retry_429_jitter_seconds": 15,
      "retry_429_max_attempts": 0
    },
    "sosovalue": {
      "enabled": false,
      "api_key_env": "SOSOVALUE_API_KEY",
      "note": "reserved for ETF flows and sector indexes if official API access exposes them"
    }
  },
  "data_quality": {
    "max_abs_price_change_24h_pct": 300,
    "max_abs_oi_change_24h_pct": 300,
    "max_abs_volume_change_24h_pct": 1000,
    "max_abs_funding_rate_pct": 2,
    "max_price_deviation_from_index_pct": 25,
    "min_quote_volume_usd": 10000000,
    "min_coinglass_exchange_count": 2
  },
  "factors": {
    "forward_return_hours": 24,
    "decay_horizons": [4, 8, 12, 24, 48, 72],
    "ic_window_days": 30,
    "min_observations": 30,
    "min_abs_ic": 0.02,
    "max_abs_weight": 0.35,
    "regime_weighting": {
      "enabled": true,
      "max_factor_multiplier": 1.35,
      "score_adjustment_strength": 0.08,
      "conflict_penalty_strength": 0.18
    },
    "priors": {
      "momentum_24h": 0.30,
      "reversal_3d": 0.08,
      "oi_price_signal": 0.2,
      "funding_rate_contrarian": 0.16,
      "ls_ratio_contrarian": 0.12,
      "liquidation_imbalance": 0.1,
      "technical_trend_4h": 0.12,
      "technical_momentum_4h": 0.08,
      "oi_acceleration_signal": 0.08,
      "funding_persistence_contrarian": 0.08,
      "taker_flow_24h": 0.07,
      "liquidation_pressure_24h": 0.07
    },
    "ic_min_periods": 10,
    "min_abs_t": 2.0,
    "ic_prior_strength": 10,
    "ic_min_cross_section": 5,
    "walk_forward_train_fraction": 0.6,
    "walk_forward_min_train_periods": 15,
    "walk_forward_min_oos_periods": 10,
    "walk_forward_robust_min_ic": 0.02,
    "walk_forward_overfit_penalty": 0.0,
    "walk_forward_gating": false,
    "regime_conditional_prior_strength": 12.0,
    "regime_min_periods": 8
  },
  "report": {
    "limit": 12,
    "core_symbols": [
      "BTC",
      "ETH",
      "SOL"
    ]
  }
}
